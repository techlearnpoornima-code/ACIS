# YouTube Data API v3 key (required for live mode)
YOUTUBE_API_KEY=AIza...

# LLM providers (Phase 2+)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# PostgreSQL (optional in Phase 1 — enables persistence + deduplication)
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://acis:changeme@localhost:5432/acis

# Hermes Agent (NousResearch) — persistent runtime, memory, scheduling, delivery
# Set to the Hermes gateway URL when running via docker-compose (see docker-compose.yml)
# When unset, ACIS writes beliefs to local output/memory.md instead
HERMES_BASE_URL=http://localhost:8765

# ACIS run config (optional overrides)
VIDEOS_PER_CHANNEL=10
MAX_CONCURRENT_CHANNELS=5
