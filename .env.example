# YouTube Data API v3 key (required for live mode)
YOUTUBE_API_KEY=AIza...

# LLM providers (Phase 2+)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# PostgreSQL (optional in Phase 1 — enables persistence + deduplication)
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://acis:changeme@localhost:5432/acis

# Transcript proxy / cookie workaround (optional — fixes YouTube IP bans)
# Proxy: any HTTP/HTTPS/SOCKS proxy URL. Residential proxies work best.
YTAPI_PROXY_URL=http://user:pass@host:port
# Cookies: path to a Netscape cookies.txt exported from a logged-in browser on youtube.com.
# Export with the "Get cookies.txt LOCALLY" Chrome/Firefox extension.
YTAPI_COOKIE_FILE=/path/to/youtube_cookies.txt

# ACIS run config (optional overrides)
VIDEOS_PER_CHANNEL=10
MAX_CONCURRENT_CHANNELS=5
